.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs de erro
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Pasta temporária do Vite
.vite/

# Arquivos de sistema e editores (Opcional, mas recomendado)
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
